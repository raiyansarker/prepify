    "@elysiajs/swagger": "^1.2.0",
    "@neondatabase/serverless": "^1.0.0",
    "ai": "^4.3.0",
    "bullmq": "^5.34.0",
    "drizzle-orm": "^0.44.2",
    "effect": "^3.14.0",
    "elysia": "^1.2.25",
    "pushduck": "^0.3.1",
    "svix": "^1.86.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@repo/shared": "workspace:*",
