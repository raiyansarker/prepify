{
  "name": "@repo/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "worker:dev": "bun run --watch src/workers/index.ts",
    "worker:dev:documents": "bun run --watch src/workers/document-processing.ts",
    "worker:dev:exam-generation": "bun run --watch src/workers/exam-generation.ts",
    "worker:dev:exam-grading": "bun run --watch src/workers/exam-grading.ts",
    "build:worker": "bun build src/workers/index.ts --outdir ./dist --target bun"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.37",
    "@ai-sdk/groq": "^3.0.27",
    "@clerk/backend": "^1.27.0",
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/openapi": "^1.4.14",
    "@huggingface/inference": "^4.13.14",
    "ai": "^6.0.108",
    "bullmq": "^5.34.0",
    "drizzle-orm": "^0.44.2",
    "effect": "^3.14.0",
    "elysia": "^1.2.25",
    "ioredis": "^5.10.0",
    "logestic": "^1.2.4",
    "pushduck": "^0.3.1",
    "ulid": "^3.0.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/shared": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/bun": "^1.2.0",
    "drizzle-kit": "^0.31.0",
    "pg": "^8.19.0",
    "typescript": "^5.9.2"
  }
}
